<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/red_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.PexelsApp</item>
    </style>

    <style name="Theme.PexelsApp" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/red_primary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>